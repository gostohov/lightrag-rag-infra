# OpenAI-compatible endpoint vLLM. Суффикс /v1 обязателен для стандартного API.
PMI_LLM_URL=https://host.example/vllm/qwen/v1

# Имя модели из ответа GET /v1/models.
PMI_LLM_MODEL=qwen3.6-27b-fp8

# Bearer token vLLM. Для локального контура может использоваться служебное значение.
PMI_LLM_API_KEY=change-me

# Общий timeout одного запроса к LLM в секундах.
PMI_TIMEOUT=600

# Базовый URL LightRAG без /query.
PMI_LIGHTRAG_URL=https://rag.example

# Значение заголовка X-API-Key для LightRAG.
PMI_LIGHTRAG_API_KEY=change-me

# Timeout длительного LightRAG /query в секундах.
PMI_LIGHTRAG_QUERY_TIMEOUT=900

# Отключить проверку корпоративного TLS-сертификата. Использовать только в PoC.
PMI_INSECURE=0

# Не использовать HTTP_PROXY/HTTPS_PROXY при обращении к внутренним сервисам.
PMI_NO_PROXY=1

# Включить отдельный live smoke-test. Обычный unit suite сеть не использует.
PMI_WORKBENCH_LIVE_SMOKE=0
