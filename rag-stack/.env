# LightRAG server
HOST=0.0.0.0
PORT=9621
LIGHTRAG_PORT=9621
WEBUI_TITLE="Corporate LightRAG"
WEBUI_DESCRIPTION="Internal RAG knowledge base"
LIGHTRAG_API_KEY=change-me
WHITELIST_PATHS=/health
ENABLE_LLM_CACHE=false
WORKING_DIR=/app/data/rag_storage
INPUT_DIR=/app/data/inputs
PROMPT_DIR=/app/data/prompts
TIKTOKEN_CACHE_DIR=/app/data/tiktoken
WORKSPACE=lightrag

# Docker images.
# On offline VMs these images must be loaded with docker load before start.
LIGHTRAG_IMAGE=lightrag:corp
OLLAMA_EMBED_IMAGE=nexus.mir:59999/ollama/ollama:0.15.2
# VLLM_EMBED_IMAGE=nexus.mir:59999/vllm/vllm-openai:v0.20.0-cu129
POSTGRES_IMAGE=nexus.mir:59999/postgres:18.4
NEO4J_IMAGE=nexus.mir:59999/neo4j:5.26.0-community-ubi9
QDRANT_IMAGE=nexus.mir:59999/qdrant/qdrant:v1.17
NGINX_IMAGE=nexus.mir:59999/nginx:latest
NGINX_HTTPS_PORT=443
LIGHTRAG_EXPOSE_PORT=9621

# Main LLM on H100.
LLM_BINDING=openai
LLM_BINDING_HOST=https://msk2-prod-ais-llm03.unix.nspk.ru/vllm/qwen/v1
LLM_BINDING_API_KEY=local-key
LLM_MODEL=qwen3-30b-fp8
MAX_ASYNC_LLM=4
LLM_TIMEOUT=240
SSL_CERT_FILE=/app/certs/llm-ca.crt
REQUESTS_CA_BUNDLE=/app/certs/llm-ca.crt

# Embedding directly on H100.
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://msk2-prod-ais-llm03.unix.nspk.ru/vllm/embed/v1
EMBEDDING_BINDING_API_KEY=local-key
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
EMBEDDING_FUNC_MAX_ASYNC=4
EMBEDDING_BATCH_NUM=16
OLLAMA_EMBED_PORT=11434
OLLAMA_MODELS_HOST_PATH=/apps/mgpt/models/ollama

# Storage stack: PostgreSQL replaces Redis from the experiment.
# Data from the corp-laptop experiment is intentionally not migrated here.
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_VECTOR_STORAGE=QdrantVectorDBStorage

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=change-me
POSTGRES_DATABASE=lightrag
POSTGRES_WORKSPACE=lightrag
POSTGRES_MAX_CONNECTIONS=25

NEO4J_URI=neo4j://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j
NEO4J_WORKSPACE=lightrag
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_INITIAL=1g
NEO4J_HEAP_MAX=4g
NEO4J_PAGECACHE=2g

QDRANT_URL=http://qdrant:6333
QDRANT_WORKSPACE=lightrag
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Stack mode: keep rerank, VLM, MinerU disabled for the first launch.
RERANK_BINDING=null
VLM_PROCESS_ENABLE=false
LIGHTRAG_PARSER=*:native-teP;*:legacy-R

# Document processing defaults.
SUMMARY_LANGUAGE=Russian
ENTITY_EXTRACTION_USE_JSON=true
MAX_PARALLEL_INSERT=2
